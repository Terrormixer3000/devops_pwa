# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Push-Subscription Datenbank (enthaelt sensible Subscription-Endpunkte)
/data/subscriptions.json
# Generated by next-pwa during build/dev (custom source stays in public/sw-custom.js)
/public/sw.js

certificates

# VSCode user settings
.vscode/settings.json
